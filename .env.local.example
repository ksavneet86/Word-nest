# Neon Postgres — create a project at neon.tech, copy the pooled connection string for
# DATABASE_URL and the direct (non-pooled) connection string for DIRECT_URL (used by
# `prisma migrate`).
DATABASE_URL=
DIRECT_URL=

# Clerk — from the Clerk dashboard for this app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Anthropic — used server-side only for word generation, file extraction, and feedback reports.
ANTHROPIC_API_KEY=

# Giphy — used server-side only for motion-clip lookups. Get a real key at
# developers.giphy.com; the app has no fallback demo key in production.
GIPHY_API_KEY=

# Optional: daily email reminders for learners who haven't practiced yet today (opt-in per
# learner, off by default). Leave blank to disable — the cron route runs harmlessly and just
# skips sending.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
# Required if deploying to Vercel with the cron in vercel.json — Vercel sends this
# automatically as a Bearer token when it invokes the cron job.
CRON_SECRET=
